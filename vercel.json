{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "routes": [
    { "src": "/", "dest": "/landing.html" },
    { "src": "/landing", "dest": "/landing.html" },
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/(.*\\.(js|css|png|jpg|ico|json|svg|woff|woff2))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
